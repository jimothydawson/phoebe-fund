---
import { DONATION_URL } from '../constants/site';

// Shared footer component
---

<footer>
    <div class="footer-content">
        <div class="footer-brand">
            <img src="/assets/06_white_logo_horizontal.png" alt="Phoebe Dawson Foundation">
            <p>Carrying forward Phoebe's legacy of love, compassion, and community. In everything we do, we ask: What Would Phoebe Do?</p>
        </div>
        <div class="footer-links">
            <h4>Foundation</h4>
            <ul>
                <li><a href="/about">About</a></li>
                <li><a href="/mission">Mission</a></li>
                <li><a href="/impact">Impact</a></li>
            </ul>
        </div>
        <div class="footer-links">
            <h4>Get Involved</h4>
            <ul>
                <li><a href="/events">Events</a></li>
                <li><a href={DONATION_URL} target="_blank">Donate</a></li>
            </ul>
        </div>
    </div>
    
    <!-- ACF Trustee Section -->
    <div class="footer-trustee">
        <a href="https://www.communityfoundation.org.au/" target="_blank" rel="noopener">
            <img src="/assets/ACF_Logo_Blue.svg" alt="Australian Communities Foundation" class="acf-logo">
        </a>
        <p>Phoebe Dawson Foundation is a Named Fund of <a href="https://www.communityfoundation.org.au/" target="_blank" rel="noopener">Australian Communities Foundation</a> which is the Trustee.</p>
    </div>
    
    <div class="footer-bottom">
        <p>&copy; 2026 Phoebe Dawson Foundation. All rights reserved.</p>
        <div class="social-links">
            <a href="https://www.linkedin.com/company/phoebe-dawson-foundation/" target="_blank">📘</a>
            <a href="https://www.instagram.com/phoebedawsonfoundation/?hl=en" target="_blank">📷</a>
            <a href="mailto:phoebedawsonfoundation@gmail.com">✉️</a>
        </div>
    </div>
</footer>

<style>
    .footer-trustee {
        max-width: 1200px;
        margin: 40px auto;
        padding: 30px 0;
        border-top: 1px solid rgba(255,255,255,0.1);
        border-bottom: 1px solid rgba(255,255,255,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 30px;
        text-align: center;
        flex-wrap: wrap;
    }
    
    .acf-logo {
        height: 50px;
        width: auto;
        background: white;
        padding: 8px 15px;
        border-radius: 0;
    }
    
    .footer-trustee p {
        font-size: 14px;
        color: rgba(255,255,255,0.7);
        margin: 0;
        max-width: 500px;
    }
    
    .footer-trustee p a {
        color: rgba(255,255,255,0.9);
        text-decoration: underline;
    }
    
    .footer-trustee p a:hover {
        color: white;
    }
    
    @media (max-width: 768px) {
        .footer-trustee {
            flex-direction: column;
            gap: 20px;
            padding: 25px 20px;
        }
    }
</style>
