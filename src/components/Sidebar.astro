---
interface Props {
    currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
---

<aside class="sidebar">
    <a href="/" class="sidebar-logo">
        <img src="/assets/06_white_logo_horizontal.png" alt="Phoebe Dawson Foundation">
    </a>
    
    <a href="https://australiacf.fcsuite.com/erp/donate/create/fund?funit_id=2094" target="_blank" class="sidebar-cta">Donate Now</a>
    
    <ul class="sidebar-nav">
        <li><a href="/" class={currentPath === '/' ? 'active' : ''}>Home</a></li>
        <li><a href="/about" class={currentPath === '/about' ? 'active' : ''}>About</a></li>
        <li><a href="/mission" class={currentPath === '/mission' ? 'active' : ''}>Mission</a></li>
        <li><a href="/impact" class={currentPath === '/impact' ? 'active' : ''}>Impact</a></li>
        <li><a href="/events" class={currentPath === '/events' ? 'active' : ''}>Events</a></li>
    </ul>
    
    <div class="sidebar-bottom">
        <!-- Newsletter link hidden until backend connected
        <a href="/#signup" class="sidebar-newsletter">
            Stay Informed ✉️
        </a>
        -->
        
        <div class="sidebar-social">
            <a href="#" title="Facebook">📘</a>
            <a href="https://www.instagram.com/phoebedawsonfoundation/?hl=en" target="_blank" title="Instagram">📷</a>
            <a href="mailto:phoebedawsonfoundation@gmail.com" title="Email">✉️</a>
        </div>
        
        <div class="sidebar-tagline">
            <strong>WWPD</strong>
            What Would Phoebe Do?
        </div>
    </div>
</aside>

